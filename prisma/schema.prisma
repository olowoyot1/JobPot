generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Country {
  id         String    @id @default(cuid())
  name       String
  flag       String
  category   String // bilateral | schengen | nonschengen
  vacancies  Int?
  salary     String
  industries String // comma-separated
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  packages   Package[]
}

model Package {
  id        String   @id @default(cuid())
  countryId String
  country   Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  tier      String // standard | express | premium | custom
  name      String
  price     Int
  currency  String   @default("GBP")
  features  String // newline-separated
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  preferred String?
  password  String
  createdAt DateTime @default(now())
  orders    Order[]
}

model Order {
  id          String   @id @default(cuid())
  ref         String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  packageId   String
  package     Package  @relation(fields: [packageId], references: [id])
  countryName String
  packageName String
  price       Int
  status      String   @default("pending") // pending | processing | approved | rejected
  createdAt   DateTime @default(now())
}
