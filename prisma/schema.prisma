generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Country {
  id         String    @id @default(cuid())
  name       String
  flag       String
  category   String // bilateral | schengen | nonschengen
  vacancies  Int?
  salary     String
  industries String // comma-separated
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  packages   Package[]
  batches    Batch[]
}

model Batch {
  id         String   @id @default(cuid())
  countryId  String
  country    Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  name       String // e.g. "January 2027 Intake"
  totalSlots Int
  startDate  DateTime?
  status     String   @default("open") // open | closed
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  orders     Order[]
}

model Package {
  id        String   @id @default(cuid())
  countryId String
  country   Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  tier      String // standard | express | premium | custom
  name      String
  price     Int
  currency  String   @default("GBP")
  features  String // newline-separated
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
}

model User {
  id                String      @id @default(cuid())
  name              String
  email             String      @unique
  phone             String?
  preferred         String?
  password          String
  resetToken        String?     @unique
  resetTokenExpiry  DateTime?
  referredById      String?
  referredBy        Affiliate?  @relation("AffiliateReferrals", fields: [referredById], references: [id])
  createdAt         DateTime    @default(now())
  orders            Order[]
  documents         Document[]
}

model Document {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // passport | cv | certificate | photo | other
  fileName  String
  fileUrl   String
  status    String   @default("pending") // pending | approved | rejected
  createdAt DateTime @default(now())
}

model Staff {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Affiliate {
  id            String       @id @default(cuid())
  name          String
  email         String       @unique
  password      String
  code          String       @unique
  commissionPct Int          @default(10)
  createdAt     DateTime     @default(now())
  referrals     User[]       @relation("AffiliateReferrals")
  commissions   Commission[]
}

model Commission {
  id          String    @id @default(cuid())
  affiliateId String
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id])
  orderId     String    @unique
  order       Order     @relation(fields: [orderId], references: [id])
  amount      Int
  status      String    @default("pending") // pending | paid
  createdAt   DateTime  @default(now())
}

model Order {
  id          String      @id @default(cuid())
  ref         String      @unique
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  packageId   String
  package     Package     @relation(fields: [packageId], references: [id])
  batchId     String?
  batch       Batch?      @relation(fields: [batchId], references: [id])
  countryName String
  packageName String
  price       Int
  status      String      @default("pending") // pending | processing | approved | rejected
  createdAt   DateTime    @default(now())
  commission  Commission?
}

model PageBlock {
  id                String   @id @default(cuid())
  type              String // hero | steps | richtext | cta | image_text | html
  order             Int      @default(0)
  visible           Boolean  @default(true)
  title             String?
  subtitle          String?
  body              String? // main text; steps use "Title :: Body" per line; html uses raw markup
  ctaLabel          String?
  ctaHref           String?
  secondaryCtaLabel String?
  secondaryCtaHref  String?
  imageUrl          String?
  imagePosition     String   @default("right") // left | right (image_text only)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model SiteSettings {
  id              String   @id @default("singleton")
  siteName        String   @default("OAATZ COSULT LTD")
  tagline         String   @default("Global Placement Marketplace")
  footerBlurb     String   @default("A global placement marketplace connecting candidates with verified international work opportunities.")
  contactEmail    String   @default("info@example.com")
  contactWhatsapp String   @default("")
  businessHours   String   @default("Mon-Fri, 09:00-18:00")
  updatedAt       DateTime @updatedAt
}
